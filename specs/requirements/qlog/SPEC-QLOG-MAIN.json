        ],
        "upstream_refs": [
          "draft-ietf-quic-qlog-main-schema-13 §3",
          "https://datatracker.ietf.org/doc/html/draft-ietf-quic-qlog-main-schema-13#section-3"
        ]
      }
    },
    {
      "id": "REQ-QLOG-MAIN-S4-0001",
      "title": "Carry component traces or trace errors in contained files",
      "statement": "A contained qlog file MUST carry component traces or explicit trace conversion errors.",
      "coverage": {
        "positive": "required",
        "negative": "required",
        "edge": "required",
        "fuzz": "deferred"
      },
      "trace": {
