        ]
      }
    },
    {
      "id": "REQ-QLOG-MAIN-S5-0001",
      "title": "Carry a single trace header in sequential files",
      "statement": "A sequential qlog file MUST carry a single trace header whose events are appended after it.",
      "coverage": {
        "positive": "required",
        "negative": "required",
        "edge": "required",
        "fuzz": "deferred"
